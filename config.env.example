# Copy this file to config.env and fill in the values
# config.env is git-ignored and should never be committed

# Airflow admin account
AIRFLOW_ADMIN_PASSWORD=

# Snowflake connection
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=AIRBNB_PIPELINE
SNOWFLAKE_SCHEMA=GOLD
SNOWFLAKE_WAREHOUSE=AIRBNB_WH
